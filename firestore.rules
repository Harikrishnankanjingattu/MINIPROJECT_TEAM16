rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == 'admin@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    // Users collection – any auth user can read all (to see company info); only admin can write
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    // Leads – authenticated users can CRUD leads; admin can do all
    match /leads/{leadId} {
      allow read, write: if request.auth != null && (resource == null || resource.data.userId == request.auth.uid || isAdmin());
    }

    // Call History – authenticated users can CRUD their own; admin all
    match /history/{historyId} {
      allow read, write: if request.auth != null 
        && (resource == null || resource.data.userId == request.auth.uid || isAdmin());
    }

    // Campaigns – authenticated users can CRUD their own; admin all
    match /campaigns/{campaignId} {
      allow read, write: if request.auth != null 
        && (resource == null || resource.data.userId == request.auth.uid || isAdmin());
    }

    // Products - users CRUD their own; admin can read/write all
    match /products/{productId} {
      allow read, update, delete: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }

    // Global settings – any authenticated user can read; only admin writes
    match /settings/{doc} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
  }
}


